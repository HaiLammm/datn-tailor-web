# Production secrets cho aodaithanhloc.com.
# Copy sang .env rồi điền giá trị thật:  cp .env.prod.example .env
# (docker compose tự đọc ./.env cho phần ${...} trong docker-compose.prod.yml)

# BẮT BUỘC — token của Cloudflare Tunnel (lấy ở Zero Trust > Networks > Tunnels).
CLOUDFLARE_TUNNEL_TOKEN=

# NÊN ĐỔI cho production (mặc định dùng giá trị dev nếu để trống — không an toàn).
# JWT_SECRET_KEY=<chuỗi ngẫu nhiên dài>
# AUTH_SECRET=<openssl rand -base64 32>
